datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output   = "./database"
}

model User {
  id    String @id
  name  String
  email String @unique
  password String
  tasks Task[]
}

model Task {
  id          String   @id
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  title       String
  description String
  createdAt   DateTime @default(now())
  done        Boolean @default(false)
  dueDate     DateTime
}
